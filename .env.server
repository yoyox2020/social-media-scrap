# Application
APP_NAME=social-intelligence
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=dev-secret-key-social-intelligence

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=social_intelligence
POSTGRES_PASSWORD=password
POSTGRES_DB=social_intelligence_db
DATABASE_URL=postgresql+asyncpg://social_intelligence:password@localhost:5432/social_intelligence_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET_KEY=dev-jwt-secret-social-intelligence
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# EnsembleData API
ENSEMBLE_DATA_BASE_URL=https://ensembledata.com/apis
ENSEMBLE_DATA_API_TOKEN=jbL1OaPYT6aW0g33
ENSEMBLE_DATA_TIMEOUT=30
ENSEMBLE_DATA_MAX_RETRIES=3

# YouTube Data API v3 (fallback otomatis saat EnsembleData quota habis HTTP 495)
YOUTUBE_DATA_API_KEY=AIzaSyAeoZahRiWewqDD16R68qRx1ON3oydZXSo

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Collector
COLLECTOR_MAX_PAGES=5
COLLECTOR_DEFAULT_PLATFORMS=tiktok,youtube,instagram

# AI Models
INDOBERT_MODEL_NAME=mdhugol/indonesia-bert-sentiment-classification
BGE_M3_MODEL_NAME=BAAI/bge-m3
GLINER_MODEL_NAME=urchade/gliner_multi-v2.1
MODELS_CACHE_DIR=./models_cache
AI_BATCH_SIZE=16

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen3:8b
OLLAMA_TIMEOUT=120

# Reports
REPORT_OUTPUT_DIR=./reports

# YouTube Pipeline
# Isi YOUTUBE_DEFAULT_PROJECT_ID dengan UUID project setelah pertama kali login & buat project
# Jika kosong, Celery Beat akan auto-detect project pertama dari DB
YOUTUBE_DEFAULT_PROJECT_ID=
YOUTUBE_TRENDING_GEO=ID
YOUTUBE_TRENDING_PERIOD=24h
YOUTUBE_TRENDING_LIMIT=10
YOUTUBE_MAX_PAGES_PER_KEYWORD=2
YOUTUBE_MAX_COMMENT_PAGES=3
YOUTUBE_MAX_COMMENTS_PER_VIDEO=100

# Rate Limiting
RATE_LIMIT_AGENTS_MAX_REQUESTS=10
RATE_LIMIT_AGENTS_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
