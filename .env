# Application
APP_NAME=social-intelligence
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=dev-secret-key-social-intelligence

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=social_intelligence
POSTGRES_PASSWORD=password
POSTGRES_DB=social_intelligence_db
DATABASE_URL=postgresql+asyncpg://social_intelligence:password@localhost:5432/social_intelligence_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET_KEY=dev-jwt-secret-social-intelligence
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# EnsembleData API
ENSEMBLE_DATA_BASE_URL=https://ensembledata.com/apis
#ENSEMBLE_DATA_API_TOKEN=wxZS9g1rR8MRemrw jbL1OaPYT6aW0g33
ENSEMBLE_DATA_API_TOKEN=jbL1OaPYT6aW0g33
ENSEMBLE_DATA_TIMEOUT=30
ENSEMBLE_DATA_MAX_RETRIES=5

# YouTube Data API v3 (fallback saat EnsembleData quota habis)
YOUTUBE_DATA_API_KEY=AIzaSyAeoZahRiWewqDD16R68qRx1ON3oydZXSo

# Apify (scraping Instagram — pengganti EnsembleData untuk Instagram)
# Nilai asli ada di .env server (bukan di sini)
APIFY_API_TOKEN=
APIFY_ACTOR_ID=ycQuEFDDZmgX7BAsL

# Instagram search provider (Apify + fallback EnsembleData) — cari & scrape
# profil by username, auto-switch kalau provider pertama gagal
INSTAGRAM_SEARCH_PROVIDER_ORDER=apify,ensembledata
INSTAGRAM_SEARCH_DAILY_MIN=3
INSTAGRAM_SHARED_DAILY_BUDGET=10

# Instagram trend-recommendation scraping (pipeline trend_recommendations, 09:00 WIB)
INSTAGRAM_TREND_DAILY_BUDGET=5
INSTAGRAM_TREND_POSTS_PER_TOPIC=3
INSTAGRAM_TREND_COMMENTS_PER_POST=10

# Viral discovery harian (AI cari topik viral, submit ke trend_recommendations)
# ANTHROPIC_API_KEY / OPENAI_API_KEY / FIRECRAWL_API_KEY / TAVILY_API_KEY: nilai asli ada di .env server (bukan di sini)
AI_DISCOVERY_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Web search untuk provider "ollama" — auto-switch: Firecrawl dicoba dulu, fallback ke Tavily
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
VIRAL_DISCOVERY_MAX_TOPICS=5

# Jadwal Celery Beat (WIB) — viral discovery jalan 2 jam sebelum scrape supaya
# topik yang ditemukan bisa kebagian scrape di hari yang sama
VIRAL_DISCOVERY_SCHEDULE_HOUR=7
VIRAL_DISCOVERY_SCHEDULE_MINUTE=0
INSTAGRAM_TREND_SCRAPE_SCHEDULE_HOUR=9
INSTAGRAM_TREND_SCRAPE_SCHEDULE_MINUTE=0

# Facebook - provider abstraction untuk pipeline trend_recommendations
# (Apify satu-satunya provider aktif, slot lain bisa ditambah nanti)
FACEBOOK_SEARCH_PROVIDER_ORDER=apify
FACEBOOK_TREND_DAILY_BUDGET=5
FACEBOOK_TREND_POSTS_PER_TOPIC=3
FACEBOOK_TREND_COMMENTS_PER_POST=10
FACEBOOK_TREND_SCRAPE_SCHEDULE_HOUR=10
FACEBOOK_TREND_SCRAPE_SCHEDULE_MINUTE=0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Collector
COLLECTOR_MAX_PAGES=5
COLLECTOR_DEFAULT_PLATFORMS=tiktok,youtube,instagram

# AI Models
INDOBERT_MODEL_NAME=mdhugol/indonesia-bert-sentiment-classification
BGE_M3_MODEL_NAME=BAAI/bge-m3
GLINER_MODEL_NAME=urchade/gliner_multi-v2.1
MODELS_CACHE_DIR=./models_cache
AI_BATCH_SIZE=16

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen3:8b
OLLAMA_TIMEOUT=120

# Reports
REPORT_OUTPUT_DIR=./reports

# YouTube Pipeline
# Isi YOUTUBE_DEFAULT_PROJECT_ID dengan UUID project setelah pertama kali login & buat project
# Jika kosong, Celery Beat akan auto-detect project pertama dari DB
YOUTUBE_DEFAULT_PROJECT_ID=b1000000-0000-0000-0000-000000000001
YOUTUBE_TRENDING_GEO=ID
YOUTUBE_TRENDING_PERIOD=24h
YOUTUBE_TRENDING_LIMIT=10
YOUTUBE_MAX_PAGES_PER_KEYWORD=2
YOUTUBE_MAX_COMMENT_PAGES=3
YOUTUBE_MAX_COMMENTS_PER_VIDEO=100

# Rate Limiting
RATE_LIMIT_AGENTS_MAX_REQUESTS=10
RATE_LIMIT_AGENTS_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
