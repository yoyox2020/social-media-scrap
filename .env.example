# Application
APP_NAME=social-intelligence
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-super-secret-key-change-in-production

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=social_intelligence
POSTGRES_PASSWORD=password
POSTGRES_DB=social_intelligence_db
DATABASE_URL=postgresql+asyncpg://social_intelligence:password@localhost:5432/social_intelligence_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# EnsembleData API
ENSEMBLE_DATA_BASE_URL=https://ensembledata.com/apis
ENSEMBLE_DATA_API_TOKEN=your-ensembledata-api-token
ENSEMBLE_DATA_TIMEOUT=30
ENSEMBLE_DATA_MAX_RETRIES=3

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Collector
COLLECTOR_MAX_PAGES=5
COLLECTOR_DEFAULT_PLATFORMS=tiktok,youtube,instagram

# AI Models (Phase 4)
INDOBERT_MODEL_NAME=mdhugol/indonesia-bert-sentiment-classification
BGE_M3_MODEL_NAME=BAAI/bge-m3
GLINER_MODEL_NAME=urchade/gliner_multi-v2.1
MODELS_CACHE_DIR=/app/models_cache
AI_BATCH_SIZE=16

# Ollama (Qwen3 8B)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_NAME=qwen3:8b
OLLAMA_TIMEOUT=120

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
